{
  "info": {
    "name": "hotelback frontend contract",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userId", "value": "101" },
    { "key": "bookingId", "value": "5001" },
    { "key": "roomId", "value": "10" },
    { "key": "notificationId", "value": "701" },
    { "key": "wishlistId", "value": "301" },
    { "key": "paymentId", "value": "801" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Bat Erdene\",\n  \"email\": \"bat@example.com\",\n  \"password\": \"secret123\",\n  \"phone\": \"+97699112233\"\n}" },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"bat@example.com\",\n  \"password\": \"secret123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create booking",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"roomId\": {{roomId}},\n  \"checkinDate\": \"2026-04-01\",\n  \"checkoutDate\": \"2026-04-03\",\n  \"firstName\": \"Bat\",\n  \"lastName\": \"Erdene\",\n  \"email\": \"bat@example.com\",\n  \"phone\": \"+97699112233\",\n  \"guestCount\": 2,\n  \"specialRequests\": \"High floor if available\"\n}" },
            "url": "{{baseUrl}}/api/bookings"
          }
        },
        {
          "name": "List bookings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/bookings"
          }
        },
        {
          "name": "Get booking detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Update booking",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"checkinDate\": \"2026-04-02\",\n  \"checkoutDate\": \"2026-04-04\",\n  \"firstName\": \"Bat\",\n  \"lastName\": \"Erdene\",\n  \"email\": \"bat@example.com\",\n  \"phone\": \"+97699112233\",\n  \"guestCount\": 2,\n  \"specialRequests\": \"Late arrival\",\n  \"status\": \"PENDING\"\n}" },
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Confirm booking",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/confirm"
          }
        },
        {
          "name": "Cancel booking",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/bookings/{{bookingId}}/cancel"
          }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "Add to wishlist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": {{userId}},\n  \"roomId\": {{roomId}}\n}" },
            "url": "{{baseUrl}}/api/wishlist"
          }
        },
        {
          "name": "List wishlist",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/wishlist/user/{{userId}}"
          }
        },
        {
          "name": "Wishlist exists",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/wishlist/user/{{userId}}/room/{{roomId}}/exists"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Create notification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": {{userId}},\n  \"title\": \"Захиалга баталгаажлаа\",\n  \"message\": \"Таны захиалга амжилттай баталгаажлаа.\",\n  \"type\": \"BOOKING\"\n}" },
            "url": "{{baseUrl}}/api/notifications"
          }
        },
        {
          "name": "List notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/notifications/user/{{userId}}"
          }
        },
        {
          "name": "Unread count",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/notifications/user/{{userId}}/unread-count"
          }
        },
        {
          "name": "Mark as read",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/notifications/{{notificationId}}/read"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"bookingId\": {{bookingId}},\n  \"amount\": 372000.00,\n  \"paymentMethod\": \"QPAY\"\n}" },
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "List payments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/payments"
          }
        },
        {
          "name": "Get payment detail",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/payments/{{paymentId}}"
          }
        }
      ]
    }
  ]
}
